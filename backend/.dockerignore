# --- Version Control ---
.git
.gitignore

# --- Secrets & Config ---
.env
*.pem
*.key
docker-compose.yml
compose.yaml

# --- Python Backend Cleanup ---
**/__pycache__/
**/*.py[cod]
**/*.so
**/.venv/
**/env/
**/venv/
**/.pytest_cache/
**/.coverage
