{
    "import": [
        {
            "name": "name",
            "label": "Model Name",
            "type": "text",
            "defaultValue": "StyleGAN2",
            "placeholder": "Enter custom model name..."
        },
        {
            "name": "checkpoint_path",
            "label": "Checkpoint Path",
            "type": "file",
            "required": true,
            "filters": [
                { "name": "PyTorch Checkpoint", "extensions": ["pt", "pth", "pkl"] }
            ],
            "placeholder": "Select StyleGAN2 checkpoint file (.pt or .pkl)"
        },
        {
            "name": "size",
            "label": "Image Resolution",
            "type": "select",
            "defaultValue": "256",
            "options": [
                { "label": "256 x 256", "value": "256" },
                { "label": "512 x 512", "value": "512" },
                { "label": "1024 x 1024", "value": "1024" }
            ]
        },
        {
            "name": "channel_multiplier",
            "label": "Channel Multiplier",
            "type": "integer",
            "defaultValue": 2,
            "placeholder": "Typically 2"
        }
    ],
    "generate": [
        {
            "name": "seed",
            "label": "Seed",
            "type": "integer",
            "defaultValue": 0,
            "placeholder": "Enter seed",
            "randomizable": true
        },
        {
            "name": "truncation",
            "label": "Truncation Value",
            "type": "float",
            "defaultValue": 0.7,
            "placeholder": "Between 0.0 and 1.0 (truncation trick)"
        }
    ],
    "invert": [
        {
            "name": "steps",
            "label": "Optimization Steps",
            "type": "integer",
            "defaultValue": 100,
            "placeholder": "Projection step count"
        }
    ]
}
