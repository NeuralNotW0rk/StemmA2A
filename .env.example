# Configuration for the Stemm A2A application.
# Copy this file to .env and modify the values for your local setup.

# Set to "true" to automatically start the local Python backend.
# Set to "false" if you are running the backend on a separate machine.
RUN_LOCAL_BACKEND=true

# The URL of the backend server.
BACKEND_URL=http://127.0.0.1:5000

# Cloudflare Access service token.
# Required for authenticating with the Cloudflare Tunnel.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Cloudflare Tunnel token for the backend server.
CF_TUNNEL_TOKEN=