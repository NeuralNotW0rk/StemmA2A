# ----------------------------------------------------------------
# Virtual File System (VFS) Configuration
# ----------------------------------------------------------------

# VFS_MODE: Determines how the application accesses files.
# - LOCAL: Access files directly on the local filesystem.
# - REMOTE_CLIENT: Act as a client to a remote VFS server (e.g., UI on laptop, server on a powerful PC).
# - REMOTE_SERVER: Act as a server, providing file access to remote clients.
VFS_MODE=LOCAL

# DATA_ROOT: The root directory for projects and models.
# - For VFS_MODE=LOCAL, this is a path on your local machine (e.g., C:/Users/YourUser/stemma2a_data).
# - For VFS_MODE=REMOTE_SERVER, this is the path inside the Docker container (e.g., /app/data).
DATA_ROOT=data

# REMOTE_URL: The URL of the remote VFS server.
# Required only when VFS_MODE is set to REMOTE_CLIENT.
REMOTE_URL=http://127.0.0.1:5000


# ----------------------------------------------------------------
# Cloudflare Tunnel (Optional)
# ----------------------------------------------------------------

# Cloudflare Access service token.
# Required for authenticating with the Cloudflare Tunnel.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Cloudflare Tunnel token for the backend server.
CF_TUNNEL_TOKEN=
